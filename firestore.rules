rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /* =========================
       🔐 HELPER FUNCTIONS
    ==========================*/

    function isLoggedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return request.auth.token.email_verified == true;
    }

    // Allow both .edu.al and .fshnstudent.info
    function isValidDomain() {
      return request.auth.token.email.matches('.*@fshnstudent\\.info$') || 
             request.auth.token.email.matches('.*@fshn\\.edu\\.al$');
    }

    function isStudent() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'STUDENT';
    }

    function isTeacher() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'TEACHER';
    }

    function isApprovedStudent() {
      return isStudent() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.is_confirmed == 1;
    }

    function sameUser(userId) {
      return request.auth.uid == userId;
    }

    function isAdmin() {
      return request.auth.token.email == "florianloka3@gmail.com" && request.auth.token.email_verified == true;
    }

    /* =========================
       👤 USERS
    ==========================*/

    match /users/{userId} {
      allow create: if isLoggedIn();
      allow read: if isLoggedIn();
      allow update: if isLoggedIn() && (sameUser(userId) || isTeacher() || isAdmin());
      allow delete: if isAdmin();
    }

    /* =========================
       🏫 CLASSES & MEMBERS
    ==========================*/

    match /classes/{classId} {
      allow read: if isLoggedIn();
      allow write: if isTeacher() || isAdmin();
    }

    match /class_members/{memberId} {
      allow read: if isLoggedIn();
      allow write: if isLoggedIn();
    }

    /* =========================
       📚 ACADEMIC CONTENT
    ==========================*/

    match /tests/{testId} {
      allow read: if isLoggedIn();
      allow write: if isTeacher() || isAdmin();
    }

    match /questions/{qId} {
      allow read: if isLoggedIn();
      allow write: if isTeacher() || isAdmin();
    }

    match /test_attempts/{attemptId} {
      allow read: if isLoggedIn();
      allow write: if isLoggedIn();
    }

    match /test_answers/{answerId} {
      allow read: if isLoggedIn();
      allow write: if isLoggedIn();
    }

    match /assignments/{assignmentId} {
      allow read: if isLoggedIn();
      allow write: if isTeacher() || isAdmin();
    }

    match /submissions/{submissionId} {
      allow read: if isLoggedIn();
      allow write: if isLoggedIn();
    }

    /* =========================
       📊 PERFORMANCE & ATTENDANCE
    ==========================*/

    match /performance_logs/{logId} {
      allow read: if isLoggedIn();
      allow write: if isTeacher() || isAdmin();
    }

    match /attendance/{attId} {
      allow read: if isLoggedIn();
      allow write: if isTeacher() || isAdmin();
    }

    match /study_sessions/{sessionId} {
      allow read: if isLoggedIn();
      allow write: if isTeacher() || isAdmin();
    }

    match /session_presence/{presenceId} {
      allow read: if isLoggedIn();
      allow write: if isLoggedIn();
    }

    /* =========================
       💬 COMMUNICATION
    ==========================*/

    match /messages/{messageId} {
      allow read: if isLoggedIn();
      allow create: if isLoggedIn();
      allow update, delete: if isAdmin();
    }

    match /live_questions/{qId} {
      allow read: if isLoggedIn();
      allow write: if isLoggedIn();
    }

    /* =========================
       🔔 NOTIFICATIONS & OTHER
    ==========================*/

    match /notifications/{notificationId} {
      allow read: if isLoggedIn() && (resource.data.user_id == request.auth.uid || sameUser(notificationId));
      allow write: if isTeacher() || isAdmin();
    }

    match /library_books/{bookId} {
      allow read: if isLoggedIn();
      allow write: if isLoggedIn();
    }

    match /schedules/{schId} {
      allow read: if isLoggedIn();
      allow write: if isTeacher() || isAdmin();
    }

    match /events/{eventId} {
      allow read: if isLoggedIn();
      allow write: if isTeacher() || isAdmin();
    }

    match /publications/{pubId} {
      allow read: if isLoggedIn();
      allow write: if isTeacher() || isAdmin();
    }
  }
}
